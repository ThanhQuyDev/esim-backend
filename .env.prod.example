NODE_ENV=production
APP_PORT=3001
APP_NAME="NestJS API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=https://yourdomain.com
BACKEND_DOMAIN=https://api.yourdomain.com

# eSIM providers
ESIMS_ACCESS_CODE=
ESIM_ACCESS_SECRET_KEY=
AIRALO_API_CLIENT_ID=
AIRALO_API_CLIENT_SECRET=
AIRALO_BASE_URL=https://partners-api.airalo.com
GADGET_KOREA_ACCESS_KEY=
GADGET_KOREA_SECRET_KEY=
GADGET_KOREA_BASE_URL=
AIRALO_WEBHOOK_SECRET=
ESIM_ACCESS_WEBHOOK_SECRET=
GADGET_KOREA_WEBHOOK_SECRET=

# Payment
ONEPAY_MERCHANT_ID=
ONEPAY_ACCESS_CODE=
ONEPAY_HASH_SECRET=
ONEPAY_PAY_URL=https://onepay.vn/paygate/vpcpay.op
ONEPAY_RETURN_URL=https://yourdomain.com/en/payment/result
ONEPAY_IPN_URL=https://api.yourdomain.com/api/payment/plan/ipn

# Database — host phải là "postgres" (tên service trong docker-compose)
DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_strong_password
DATABASE_NAME=your_db_name
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

# File storage
FILE_DRIVER=local
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_S3_REGION=
AWS_DEFAULT_S3_BUCKET=

# Mail — dùng SMTP thật (Resend, SendGrid, v.v.)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USER=resend
MAIL_PASSWORD=your_resend_api_key
MAIL_IGNORE_TLS=false
MAIL_SECURE=true
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@yourdomain.com
MAIL_DEFAULT_NAME=YourAppName
MAIL_CLIENT_PORT=1080

# JWT — dùng secret mạnh, random 64+ ký tự
AUTH_JWT_SECRET=change_me_to_a_strong_random_secret
AUTH_JWT_TOKEN_EXPIRES_IN=365d
AUTH_REFRESH_SECRET=change_me_to_another_strong_secret
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d
AUTH_FORGOT_SECRET=change_me_forgot_secret
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=change_me_confirm_secret
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

# OAuth (nếu dùng)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_APP_AUDIENCE=[]
